</div>








<script>
function switchPlayer(element) {
    // 1. Gérer les classes actives des onglets
    var tabs = document.querySelectorAll('.player-tab');
    for (var i = 0; i < tabs.length; i++) {
        tabs[i].classList.remove('active');
    }
    element.classList.add('active');
    
    // 2. Cacher tous les lecteurs et arrêter leur flux (son et vidéo)
    var contents = document.querySelectorAll('.player-content');
    for (var j = 0; j < contents.length; j++) {
        var playerDiv = contents[j];
        var iframe = playerDiv.querySelector('iframe');
        
        if (iframe) {
            // Sauvegarder l'URL d'origine si ce n'est pas déjà fait
            if (!iframe.getAttribute('data-src')) {
                iframe.setAttribute('data-src', iframe.src);
            }
            // Vider la source pour couper instantanément le son et la vidéo
            iframe.src = '';
        }
        playerDiv.style.display = 'none';
    }
    
    // 3. Afficher le lecteur actif et relancer son flux
    var targetId = element.getAttribute('data-target');
    var targetPlayer = document.getElementById(targetId);
    if (targetPlayer) {
        targetPlayer.style.display = 'block';
        var activeIframe = targetPlayer.querySelector('iframe');
        if (activeIframe) {
            var originalSrc = activeIframe.getAttribute('data-src');
            if (originalSrc) {
                activeIframe.src = originalSrc;
            }
        }
    }
}

document.addEventListener('DOMContentLoaded', function() {
    var firstTab = document.querySelector('.player-tab');
    if (firstTab) {
        // Initialiser au chargement pour s'assurer que seuls les flux actifs consomment de la bande passante et du son
        switchPlayer(firstTab);
    }
});
</script>

