			var btns = document.getElementById('playerBtns');
			var actions = document.getElementById('playerActions');
			var theaterBtn = document.getElementById('theaterBtn');
			var copyBtn = document.getElementById('copyEmbed');

			function updateAll(url) {
			    if (!url) return;
			
			    if (iframe) {
			        // 🔥 safest reload method (no blank state)
			        var newFrame = iframe.cloneNode();
			
			        newFrame.src = url;
			        newFrame.id = iframe.id;
			
			        iframe.parentNode.replaceChild(newFrame, iframe);
			        iframe = newFrame;
			    }
			
			    if (ta) {
			        ta.value = '<iframe src="' + url + '" width="100%" height="100%" style="border:0;" allowfullscreen></iframe>';
			    }
			}

			if (btns) {
				btns.addEventListener('click', function (e) {
					var btn = e.target.closest('.player-btn');
					if (!btn || !btns.contains(btn)) return;

					var url = btn.getAttribute('data-url');
					if (!url) return;

					updateAll(url);

					btns.querySelectorAll('.player-btn').forEach(function (b) {
						b.classList.remove('is-active');
					});

					btn.classList.add('is-active');
				});
			}

			function updateFade() {
				if (!btns || !actions) return;

				var canScroll = btns.scrollWidth > btns.clientWidth + 2;
				actions.classList.toggle('is-scrollable', canScroll);

				var atEnd = Math.ceil(btns.scrollLeft + btns.clientWidth) >= btns.scrollWidth;
				actions.classList.toggle('is-end', atEnd || !canScroll);
			}

			if (btns && actions) {
				btns.addEventListener('scroll', updateFade, { passive: true });
				window.addEventListener('resize', updateFade, { passive: true });
				updateFade();
			}

			if (copyBtn && ta) {
				copyBtn.addEventListener('click', function () {
					var text = ta.value;

					if (navigator.clipboard && navigator.clipboard.writeText) {
						navigator.clipboard.writeText(text).catch(function () {
							ta.select();
							document.execCommand('copy');
						});
						return;
					}

					ta.select();
					document.execCommand('copy');
				});
			}

			if (theaterBtn) {
				theaterBtn.addEventListener('click', function () {
					document.documentElement.classList.toggle('theater-mode');

					try {
						localStorage.setItem(
							'theater-mode',
							document.documentElement.classList.contains('theater-mode') ? '1' : '0'
						);
					} catch (e) {}
				});

				try {
					if (localStorage.getItem('theater-mode') === '1') {
						document.documentElement.classList.add('theater-mode');
					}
				} catch (e) {}
			}
		})();
		</script>
	
	<p><a href="/24-7-channels.php">Back to channels</a></p>
</section>

