    var WSreloadCounter = false, WSnTries = 0;
    var isMobile = /android|ipad|ipod|iphone|blackberry|iemobile|opera mini|mobile/i.test(navigator.userAgent);

    var elUnmute  = document.getElementById("UnMutePlayer");
    var elOffline = document.querySelector(".stream-offline");
    var elCounter = document.querySelector(".stream-offline .counter");

    function errorPlaying() {
        elUnmute.style.display = "none";
        elCounter.textContent = 10;
        elOffline.style.display = "table";
        if (!WSreloadCounter) WSreloadCounter = setInterval(function() {
            var a = parseInt(elCounter.textContent);
            if (a > 1) {
                elCounter.textContent = --a;
            } else {
                clearInterval(WSreloadCounter);
                WSreloadCounter = false;
                WSnTries++;
                if (WSnTries < 10) {
                    elOffline.style.display = "none";
                    setTimeout(function() {
                        player.configure(player.options);
                    }, 1000);
                } else {
                    window.location.reload();
                }
            }
        }, 1000);
    }

    function WSUnmute() {
        elUnmute.style.display = "none";
        player.setVolume(100);
    }

    var p2pConfig = {
        channelId : 'cdn11.zohanayaan.com:1686/hls/wsmkmlfeed01',
        segmentId: function (streamId, sn, url, range) {
            let netUrl = url.split('?')[0];
            if (netUrl.startsWith('http')) {
                netUrl = netUrl.split('://')[1];
            }
            if (range) {
                return `${netUrl}|${range}`;
            }
            return `${netUrl}`;
        },
        token: 'drama',
        live: true,
        swFile: './sw.js',
        getStats: function (totalP2PDownloaded, totalP2PUploaded, totalHTTPDownloaded) {
            var total = totalHTTPDownloaded + totalP2PDownloaded;
            console.log(`p2p ratio: ${Math.round(totalP2PDownloaded/total*100)}%`);
        }
    }

    var playerElement = document.getElementById("player");
    var player = new Clappr.Player({
        height: "100%",
        width: "100%",
        autoPlay: true,
        mute: true,
        disableErrorScreen: true,
        preload: true,
        plugins: [HlsjsPlayback],
        mediacontrol: {buttons: "#7cafa0"},
        playback: {
            hlsjsConfig: {
                maxBufferSize: 0,
                maxBufferLength: 10,
                liveSyncDurationCount: 7,
                liveMaxLatencyDurationCount: 10,
                enableWorker: true,
                p2pConfig
            }
        },
        events: {
            onError: function(e) {
                errorPlaying();
            },
            onPlay: function(e) {
                elOffline.style.display = "none";
                WSreloadCounter && clearInterval(WSreloadCounter);
                WSreloadCounter = false;
                WSnTries = 0;
                elUnmute.style.display = "block";
            },
            onVolumeUpdate: function(e) {
                elUnmute.style.display = "none";
            }
        }
    });

    player.on(Clappr.Events.PLAYER_ERROR, function() {
        errorPlaying();
    });

    player.attachTo(playerElement);

    P2PEngineHls.tryRegisterServiceWorker(p2pConfig).then(() => {
        player.load({source: elttrpgUHt(), mimeType: 'application/vnd.apple.mpegurl'});
        p2pConfig.hlsjsInstance = player.core.getCurrentPlayback()?._hls;
        var engine = new P2PEngineHls(p2pConfig);
        player.play();
    });

    function elttrpgUHt() {
        return(["h","t","t","p","s",":","\/","\/","c","d","n","1","1",".","z","o","h","a","n","a","y","a","a","n",".","c","o","m",":","1","6","8","6","\/","h","l","s","\/","w","s","m","k","m","l","f","e","e","d","0","1",".","m","3","u","8","?","m","d","5","=","p","R","Z","J","j","3","B","9","E","i","r","0","p","v","-","C","z","o","9","R","2","A","&","e","x","p","i","r","e","s","=","1","7","8","1","8","9","8","2","7","8"].join("") + sryeSirnabagrtUarueAl.join("") + document.getElementById("gattkrsnhaBiefucSi").innerHTML);
    }
